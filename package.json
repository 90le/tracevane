    "smoke:workspace:document-modes": "npm run build:web && python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/preview-web-smoke.sh\" --port 5176 -- node tests/file-manager/workspace-document-modes.smoke.mjs"
