{
  "name": "@binbin/tracevane",
  "version": "0.1.70",
  "description": "Tracevane - Local AI Agent Control Workbench",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "openclaw": {
    "id": "tracevane",
    "extensions": [
      "./index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "install": {
      "minHostVersion": ">=2026.4.8"
    },
    "kind": "ui",
    "installDependencies": true
  },
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "build:api": "node scripts/clean-build-output.mjs api && tsc -p tsconfig.json",
    "build": "npm run build:web && npm run build:api",
    "build:web": "node scripts/clean-build-output.mjs web && npm run build --workspace=apps/web",
    "dev:api": "npm run build:api && node scripts/start-standalone-api.mjs",
    "dev:fresh": "bash scripts/dev-fresh.sh",
    "dev:restart": "bash scripts/restart-dev.sh",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:web:smoke": "bash scripts/dev-web-smoke.sh",
    "smoke:model-gateway:cli": "npm run build:api && node scripts/smoke-model-gateway-cli.mjs",
    "smoke:model-gateway:cli:strict": "npm run build:api && node scripts/smoke-model-gateway-cli.mjs --strict",
    "smoke:model-gateway:live": "npm run build:api && node scripts/smoke-model-gateway-live.mjs",
    "smoke:model-gateway:live:strict": "npm run build:api && node scripts/smoke-model-gateway-live.mjs --strict",
    "smoke:model-gateway:active-routes": "node scripts/smoke-model-gateway-active-routes.mjs",
    "smoke:model-gateway:protocol-matrix": "node scripts/smoke-model-gateway-protocol-matrix.mjs",
    "smoke:model-gateway:account-pool": "node scripts/smoke-model-gateway-account-pool.mjs",
    "smoke:channel-connectors:persistent-live": "npm run build:api && node scripts/smoke-channel-connectors-persistent-live.mjs",
    "smoke:channel-connectors:agent-sessions": "node scripts/smoke-channel-connectors-agent-sessions.mjs",
    "smoke:channel-connectors:agent-runner-direct": "npm run build:api && node scripts/smoke-channel-connectors-agent-runner-direct.mjs",
    "smoke:channel-connectors:agent-heartbeat-local": "npm run build:api && node scripts/smoke-channel-connectors-agent-heartbeat-local.mjs",
    "smoke:channel-connectors:native-cli-sessions": "npm run build:api && node scripts/smoke-channel-connectors-native-cli-sessions.mjs",
    "smoke:channel-connectors:native-cli-sessions:strict": "npm run build:api && node scripts/smoke-channel-connectors-native-cli-sessions.mjs --strict",
    "smoke:channel-connectors:feishu-long-connection": "node scripts/smoke-channel-connectors-feishu-long-connection.mjs",
    "test:system": "npm run build:api && node --test tests/system/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:api": "tsc -p tsconfig.json --noEmit",
    "typecheck:web": "npm run typecheck --workspace=apps/web",
    "install:all": "npm install && npm install --workspace=apps/web",
    "smoke:file-manager:mobile-layout": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-mobile-layout.smoke.mjs",
    "smoke:file-manager:text-editor": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-text-editor.smoke.mjs",
    "smoke:file-manager:selection": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-selection.smoke.mjs",
    "smoke:file-manager:content-index": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-content-index.smoke.mjs",
    "smoke:file-manager:quick-paste-upload": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-quick-paste-upload.smoke.mjs",
    "smoke:file-manager:upload-conflicts": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-upload-conflicts.smoke.mjs",
    "smoke:file-manager:list-preferences": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"TRACEVANE_SMOKE_FORCE_OPTIMIZE=1 exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-list-preferences.smoke.mjs",
    "smoke:file-manager:large-directory": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-large-directory.smoke.mjs",
    "smoke:file-manager:file-operations": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-file-operations.smoke.mjs",
    "smoke:file-manager:upload-resumable": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-upload-resumable.smoke.mjs",
    "test:web:api": "node --test tests/system/web-model-gateway.test.mjs tests/system/web-api-client.test.mjs",
    "smoke:file-manager:online-editor": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-online-editor.smoke.mjs",
    "smoke:file-manager:online-editor-responsive": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-online-editor-responsive.smoke.mjs",
    "smoke:file-manager:favorites": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-favorites.smoke.mjs",
    "generate:monaco-languages": "node scripts/generate-monaco-language-loaders.mjs",
    "smoke:file-manager:monaco-highlighting": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-monaco-highlighting.smoke.mjs",
    "smoke:file-manager:monaco-clipboard": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-monaco-clipboard.smoke.mjs",
    "smoke:file-manager:monaco-nls": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-monaco-nls.smoke.mjs",
    "smoke:file-manager:file-surface-routing": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-file-surface-routing.smoke.mjs",
    "smoke:file-manager:media-preview": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- node tests/file-manager/file-manager-media-preview.smoke.mjs",
    "smoke:ide:workbench-layout": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port ${TRACEVANE_WEB_PORT:-5176} -- node tests/ide-workbench/ide-workbench-layout.smoke.mjs",
    "smoke:ide:editor-foundation": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port ${TRACEVANE_WEB_PORT:-5176} -- node tests/ide-workbench/ide-editor-foundation.smoke.mjs",
    "smoke:ide:terminal-foundation": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port ${TRACEVANE_WEB_PORT:-5176} -- node tests/ide-workbench/ide-terminal-foundation.smoke.mjs",
    "smoke:ide:terminal-split-layout": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port ${TRACEVANE_WEB_PORT:-5176} -- node tests/ide-workbench/ide-terminal-split-layout.smoke.mjs",
    "smoke:ide:terminal-panel-placement": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port ${TRACEVANE_WEB_PORT:-5176} -- node tests/ide-workbench/ide-terminal-panel-placement.smoke.mjs",
    "smoke:ide:terminal-persistence": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port ${TRACEVANE_WEB_PORT:-5176} -- node tests/ide-workbench/ide-terminal-persistence.smoke.mjs",
    "smoke:ide:terminal-durable-backend": "node tests/ide-workbench/ide-terminal-durable-backend.smoke.mjs",
    "smoke:ide:editor-save-dirty": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port ${TRACEVANE_WEB_PORT:-5176} -- node tests/ide-workbench/ide-editor-save-dirty.smoke.mjs"
  },
  "author": "binbin",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@larksuiteoapi/node-sdk": "^1.66.1",
    "bcryptjs": "^2.4.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.14",
    "@types/ws": "^8.18.1",
    "typescript": "^5.3.0"
  }
}
