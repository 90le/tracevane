    "docs:render:verify-reader": "python3 tools/docs-renderer/tests/playwright_reader_settings_regression.py",
    "docs:render:verify-back-to-top": "python3 tools/docs-renderer/tests/playwright_back_to_top_regression.py",
    "docs:render:verify-feedback": "python3 tools/docs-renderer/tests/playwright_feedback_regression.py",
    "docs:render:verify-keyboard-help": "python3 tools/docs-renderer/tests/playwright_keyboard_help_regression.py",
    "docs:render:verify-quick-actions": "python3 tools/docs-renderer/tests/playwright_quick_actions_regression.py",
