{
  "name": "@binbin/tracevane",
  "version": "0.1.70",
  "description": "Tracevane - Local AI Agent Control Workbench",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "openclaw": {
    "id": "tracevane",
    "extensions": [
      "./index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "install": {
      "minHostVersion": ">=2026.4.8"
    },
    "kind": "ui",
    "installDependencies": true
  },
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "build:api": "node scripts/clean-build-output.mjs api && tsc -p tsconfig.json",
    "build": "npm run build:web && npm run build:api",
    "build:web": "node scripts/clean-build-output.mjs web && npm run build --workspace=apps/web",
    "dev:api": "npm run build:api && node scripts/start-standalone-api.mjs",
    "dev:fresh": "bash scripts/dev-fresh.sh",
    "dev:restart": "bash scripts/restart-dev.sh",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:web:smoke": "bash scripts/dev-web-smoke.sh",
    "docs:render": "python3 tools/docs-renderer/render-docs.py",
    "docs:render:smoke": "python3 tools/docs-renderer/smoke-test.py",
    "smoke:model-gateway:cli": "npm run build:api && node scripts/smoke-model-gateway-cli.mjs",
    "smoke:model-gateway:cli:strict": "npm run build:api && node scripts/smoke-model-gateway-cli.mjs --strict",
    "smoke:model-gateway:live": "npm run build:api && node scripts/smoke-model-gateway-live.mjs",
    "smoke:model-gateway:live:strict": "npm run build:api && node scripts/smoke-model-gateway-live.mjs --strict",
    "smoke:model-gateway:active-routes": "node scripts/smoke-model-gateway-active-routes.mjs",
    "smoke:model-gateway:protocol-matrix": "node scripts/smoke-model-gateway-protocol-matrix.mjs",
    "smoke:model-gateway:account-pool": "node scripts/smoke-model-gateway-account-pool.mjs",
    "smoke:channel-connectors:persistent-live": "npm run build:api && node scripts/smoke-channel-connectors-persistent-live.mjs",
    "smoke:channel-connectors:agent-sessions": "node scripts/smoke-channel-connectors-agent-sessions.mjs",
    "smoke:channel-connectors:agent-runner-direct": "npm run build:api && node scripts/smoke-channel-connectors-agent-runner-direct.mjs",
    "smoke:channel-connectors:agent-heartbeat-local": "npm run build:api && node scripts/smoke-channel-connectors-agent-heartbeat-local.mjs",
    "smoke:channel-connectors:native-cli-sessions": "npm run build:api && node scripts/smoke-channel-connectors-native-cli-sessions.mjs",
    "smoke:channel-connectors:native-cli-sessions:strict": "npm run build:api && node scripts/smoke-channel-connectors-native-cli-sessions.mjs --strict",
    "smoke:channel-connectors:feishu-long-connection": "node scripts/smoke-channel-connectors-feishu-long-connection.mjs",
    "smoke:chat:browser": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/browser.acceptance.py",
    "smoke:chat:composer-draft": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/composer-draft.acceptance.py",
    "smoke:chat:composer-draft-attachment": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/composer-draft-attachment.acceptance.py",
    "smoke:chat:composer-draft-pagehide": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/composer-draft-pagehide.acceptance.py",
    "smoke:chat:composer-draft-session-switch-race": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/composer-draft-session-switch-race.acceptance.py",
    "smoke:chat:composer-autofocus": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/composer-autofocus.acceptance.py",
    "smoke:chat:composer-paste-mixed": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/composer-paste-mixed.acceptance.py",
    "smoke:chat:composer-attachment": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/composer-attachment.acceptance.py",
    "smoke:chat:composer-upload-concurrency": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/composer-upload-concurrency.acceptance.py",
    "smoke:chat:composer-upload-nonpreview": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/composer-upload-nonpreview.acceptance.py",
    "smoke:chat:composer-upload-session-switch": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/composer-upload-session-switch.acceptance.py",
    "smoke:chat:composer-upload-cancel": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/composer-upload-cancel.acceptance.py",
    "smoke:chat:composer-upload-remove": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/composer-upload-remove.acceptance.py",
    "smoke:chat:composer-ime": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/composer-ime.acceptance.py",
    "smoke:chat:gateway": "python tests/chat/gateway.acceptance.py",
    "smoke:chat:heavy-history": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/heavy-history.acceptance.py",
    "smoke:chat:jump-latest": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/jump-latest.acceptance.py",
    "smoke:chat:downward-history": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/downward-history.acceptance.py",
    "smoke:chat:session-rail": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/session-rail.acceptance.py",
    "smoke:chat:session-delete-cache-cleanup": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/session-delete-cache-cleanup.acceptance.py",
    "smoke:chat:fresh-tool": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/fresh-tool.acceptance.py",
    "smoke:chat:im": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/chat-im.acceptance.py",
    "smoke:chat:matrix": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/smoke-matrix.py --profile core",
    "smoke:chat:matrix:full": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/smoke-matrix.py --profile full",
    "smoke:chat:surface": "python /home/binbin/.agents/skills/webapp-testing/scripts/with_server.py --server \"exec bash scripts/dev-web-smoke.sh\" --port 5176 -- python tests/chat/surface.acceptance.py",
    "test:chat": "npm run build:api && node --test tests/chat/*.test.mjs",
    "test:system": "npm run build:api && node --test tests/system/*.test.mjs",
    "test:chat:web": "node --test tests/system/web-model-gateway.test.mjs tests/system/web-api-client.test.mjs",
    "test:chat:integration": "npm run build:api && TRACEVANE_ENABLE_REAL_CHAT_INTEGRATION=1 TRACEVANE_TEST_OPENCLAW_ROOT=/home/binbin/.openclaw node --test tests/chat/api.integration.test.mjs tests/chat/transport.integration.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:api": "tsc -p tsconfig.json --noEmit",
    "typecheck:web": "npm run typecheck --workspace=apps/web",
    "install:all": "npm install && npm install --workspace=apps/web",
    "docs:render:verify-search": "python3 tools/docs-renderer/tests/playwright_search_regression.py",
    "docs:render:verify-browser": "python3 tools/docs-renderer/tests/playwright_browser_viewer_regression.py",
    "docs:render:verify-media": "python3 tools/docs-renderer/tests/playwright_media_lightbox_regression.py",
    "docs:render:verify-export": "python3 tools/docs-renderer/tests/playwright_export_regression.py",
    "docs:render:verify-code": "python3 tools/docs-renderer/tests/playwright_code_regression.py",
    "docs:render:verify-table": "python3 tools/docs-renderer/tests/playwright_table_regression.py",
